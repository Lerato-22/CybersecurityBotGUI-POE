<Window x:Class="CybersecurityBotGUI_part_2.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Quiz" Height="600" Width="700"
        Background="#0d0d1a" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <!-- Quiz Panel -->
        <StackPanel x:Name="QuestionPanel">

            <TextBlock Text="🎮 Cybersecurity Quiz" Foreground="#7b2fbe"
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock x:Name="QuestionNumber" Foreground="#aaaaaa"
                       FontSize="13" Margin="0,0,0,10"/>

            <Border Background="#1a1a2e" CornerRadius="10" Padding="20"
                    BorderBrush="#7b2fbe" BorderThickness="1" Margin="0,0,0,20">
                <TextBlock x:Name="QuestionText" Foreground="White"
                           FontSize="16" TextWrapping="Wrap" LineHeight="24"/>
            </Border>

            <StackPanel x:Name="AnswerPanel" Margin="0,0,0,10"/>

            <Border x:Name="FeedbackText" Background="#1a1a2e" CornerRadius="8"
                    Padding="12" Margin="0,0,0,10" Visibility="Collapsed"
                    BorderBrush="#7b2fbe" BorderThickness="1">
                <TextBlock x:Name="FeedbackTextBlock" Foreground="LightGreen"
                           FontSize="13" TextWrapping="Wrap"/>
            </Border>

            <Button x:Name="NextButton" Content="Next ➡" Click="NextButton_Click"
                    Background="#7b2fbe" Foreground="White"
                    Padding="12,8" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand"
                    HorizontalAlignment="Right"
                    Visibility="Collapsed"/>
        </StackPanel>

        <!-- Results Panel -->
        <StackPanel x:Name="ResultPanel" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="🏁 Quiz Complete!" Foreground="#7b2fbe"
                       FontSize="26" FontWeight="Bold" TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="ScoreText" Foreground="White"
                       FontSize="48" FontWeight="Bold" TextAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="ResultMessage" Foreground="LightGreen"
                       FontSize="16" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,30"/>

            <Button Content="🔄 Play Again" Click="RestartButton_Click"
                    Background="#7b2fbe" Foreground="White"
                    Padding="16,10" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>