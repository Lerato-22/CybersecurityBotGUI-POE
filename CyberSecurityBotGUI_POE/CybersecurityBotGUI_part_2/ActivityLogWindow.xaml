<Window x:Class="CybersecurityBotGUI_part_2.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Log" Height="500" Width="600"
        Background="#0d0d1a" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📋 Activity Log"
                   Foreground="#7b2fbe" FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Log List -->
        <Border Grid.Row="1" Background="#1a1a2e" CornerRadius="10"
                Padding="15" BorderBrush="#7b2fbe" BorderThickness="1"
                Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="LogPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="🔄 Show More" Click="ShowMore_Click"
                    Background="#7b2fbe" Foreground="White"
                    Padding="12,8" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand"
                    Margin="0,0,10,0"/>
            <Button Content="✖ Close" Click="Close_Click"
                    Background="#333" Foreground="White"
                    Padding="12,8" BorderThickness="0"
                    FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>