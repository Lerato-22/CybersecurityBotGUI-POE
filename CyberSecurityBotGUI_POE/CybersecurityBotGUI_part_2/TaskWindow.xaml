<Window x:Class="CybersecurityBotGUI_part_2.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="600" Width="800"
        Background="#0d0d1a" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🛡️ Cybersecurity Task Manager"
                   Foreground="#7b2fbe" FontSize="22" FontWeight="Bold"
                   Margin="0,0,0,20"/>
        <!-- Add Task Form -->
        <Border Grid.Row="1" Background="#1a1a2e" CornerRadius="10"
                Padding="15" Margin="0,0,0,20"
                BorderBrush="#7b2fbe" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Add New Task" Foreground="White"
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Title:" Foreground="#aaaaaa" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleInput" Background="#0d0d1a" Foreground="White"
                         BorderBrush="#7b2fbe" Padding="8" Margin="0,0,0,10"/>
                <TextBlock Text="Description:" Foreground="#aaaaaa" Margin="0,0,0,4"/>
                <TextBox x:Name="DescInput" Background="#0d0d1a" Foreground="White"
                         BorderBrush="#7b2fbe" Padding="8" Margin="0,0,0,10"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                <TextBlock Text="Reminder Date (optional):" Foreground="#aaaaaa" Margin="0,0,0,4"/>
                <DatePicker x:Name="ReminderPicker" Background="#0d0d1a"
                            Foreground="White" Margin="0,0,0,10"/>
                <Button Content="➕ Add Task" Click="AddTask_Click"
                        Background="#7b2fbe" Foreground="White"
                        Padding="12,8" BorderThickness="0"
                        FontWeight="Bold" Cursor="Hand"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
        <!-- Task List -->
        <Border Grid.Row="2" Background="#1a1a2e" CornerRadius="10"
                Padding="15" BorderBrush="#7b2fbe" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Your Tasks" Foreground="White"
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TaskList"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>